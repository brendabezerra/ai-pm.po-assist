{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Follow-up Output",
  "description": "Output format for follow-up communications generated from meetings.",
  "type": "object",
  "required": ["meeting_title", "messages"],
  "properties": {
    "meeting_title": { "type": "string" },
    "project": { "type": "string" },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "channel": { "type": "string", "enum": ["email", "whatsapp", "telegram"] },
          "to": { "type": "array", "items": { "type": "string" } },
          "subject": { "type": "string" },
          "body": { "type": "string" },
          "purpose": {
            "type": "string",
            "enum": ["share_notes", "assign_task", "request_update", "escalate", "inform"]
          },
          "requires_confirmation": { "type": "boolean", "default": true }
        },
        "required": ["channel", "to", "body"]
      }
    },
    "documents_to_create": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["prd", "design_doc", "story", "meeting_notes"] },
          "title": { "type": "string" },
          "context": { "type": "string" }
        }
      }
    }
  }
}
