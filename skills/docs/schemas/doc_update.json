{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Document Update",
  "description": "Schema for document update requests.",
  "type": "object",
  "required": ["file_path", "changes"],
  "properties": {
    "file_path": {
      "type": "string",
      "description": "Path to the existing document"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "section": {
            "type": "string",
            "description": "Which section to update"
          },
          "action": {
            "type": "string",
            "enum": ["replace", "append", "prepend"]
          },
          "content": { "type": "string" },
          "reason": { "type": "string" }
        },
        "required": ["section", "action", "content"]
      }
    },
    "source": {
      "type": "string",
      "description": "What triggered this update (meeting, email, conversation)"
    },
    "project": { "type": "string" }
  }
}
